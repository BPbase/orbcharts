{
  "name": "orbcharts",
  "version": "4.0.0-alpha.0",
  "description": "OrbCharts is a data-driven Javascript chart library",
  "author": "Blue Planet Inc.",
  "license": "Apache-2.0",
  "keywords": [
    "d3",
    "rxjs",
    "typescript",
    "svg",
    "visualization",
    "infographic",
    "graph",
    "chart"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "*"
  ],
  "main": "./dist/orbcharts.umd.js",
  "module": "./dist/orbcharts.es.js",
  "types": "./dist/src/index.d.ts",
  "unpkg": "./dist/orbcharts.umd.js",
  "jsdelivr": "./dist/orbcharts.umd.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "vite build --mode production",
    "prepublishOnly": "echo $npm_config_user_agent | grep -q '^pnpm' || { echo '請使用 pnpm publish，不要用 npm publish'; exit 1; }"
  },
  "devDependencies": {
    "@types/d3": "^7.4.0",
    "ts-loader": "^9.4.2",
    "typescript": "^5.9.2",
    "vite": "^5.3.5",
    "vite-plugin-dts": "^3.7.3"
  },
  "dependencies": {
    "@orbcharts/core": "workspace:*",
    "@orbcharts/plugin-basic": "workspace:*",
    "d3": "^7.9.0",
    "rxjs": "^7.8.2"
  }
}
